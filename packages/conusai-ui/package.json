{
  "name": "@conusai/ui",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./motion": {
      "types": "./dist/motion.d.ts",
      "import": "./dist/motion.js",
      "require": "./dist/motion.cjs"
    },
    "./theme-provider": {
      "types": "./dist/theme-provider.d.ts",
      "import": "./dist/theme-provider.js",
      "require": "./dist/theme-provider.cjs"
    },
    "./component-preview": {
      "types": "./dist/component-preview.d.ts",
      "import": "./dist/component-preview.js",
      "require": "./dist/component-preview.cjs"
    },
    "./tailwind": {
      "types": "./dist/tailwind.d.ts",
      "import": "./dist/tailwind.js",
      "require": "./dist/tailwind.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts"
  },
  "sideEffects": false,
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "radix-ui": "^1.4.3"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0"
  }
}
